@using AuthBlocksModels.SystemDefinitions
@using AuthBlocksWeb.HierarchicalAuthorize

@inject NavigationManager Navigation

@attribute [HierarchicalRoleAuthorize(SystemRoleConstants.UserAdmin)]
@page "/account/superregister"
@rendermode InteractiveServer

<PageTitle>Redirecting…</PageTitle>

@code {
    // SuperRegister was absorbed by the canonical direct-provision page at
    // /useradmin/users/new. This route is retained only to redirect old links.
    protected override void OnInitialized()
    {
        Navigation.NavigateTo("/useradmin/users/new", forceLoad: true, replace: true);
    }
}
